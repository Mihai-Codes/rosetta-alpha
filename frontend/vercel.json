{
  "framework": "nextjs",
  "installCommand": "npm ci --ignore-scripts --legacy-peer-deps",
  "buildCommand": "npx prisma generate && next build",
  "env": {
    "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD": "1",
    "PRISMA_CLI_QUERY_ENGINE_TYPE": "library",
    "PRISMA_CLIENT_ENGINE_TYPE": "library"
  }
}

