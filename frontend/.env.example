# =============================================================================
# Rosetta Alpha — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
#
# Categories:
#   [Required]  — App won't start without these
#   [Optional]  — Features degrade gracefully if missing
#   [Public]    — Exposed to browser via NEXT_PUBLIC_ prefix (NOT secrets)
#   [Server]    — Only available in API routes and server components
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Authentication (Required)
# ─────────────────────────────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=your-auth-secret-here                    # [Required] [Server]

# Production URL — must match your Vercel deployment domain exactly
AUTH_URL=https://rosetta-alpha.vercel.app            # [Required] [Server]

# Auth.js trusts the host header (needed behind Vercel proxy)
AUTH_TRUST_HOST=true                                # [Required] [Server]

# ─────────────────────────────────────────────────────────────────────────────
# OAuth Providers (Required for social login)
# ─────────────────────────────────────────────────────────────────────────────
# Google: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=your-google-client-id                # [Required] [Server]
AUTH_GOOGLE_SECRET=your-google-client-secret        # [Required] [Server]

# GitHub: https://github.com/settings/developers
AUTH_GITHUB_ID=your-github-client-id                # [Required] [Server]
AUTH_GITHUB_SECRET=your-github-client-secret        # [Required] [Server]

# Apple: https://developer.apple.com/account/resources/identifiers
AUTH_APPLE_ID=your-apple-service-id                 # [Required] [Server]
AUTH_APPLE_SECRET=your-apple-private-key            # [Required] [Server]

# ─────────────────────────────────────────────────────────────────────────────
# Email (Optional — needed for magic link emails)
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key               # [Optional] [Server]
EMAIL_FROM=Terminal <onboarding@resend.dev>         # [Optional] [Server]

# ─────────────────────────────────────────────────────────────────────────────
# Arc Testnet (Required)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ARC_CHAIN_ID=5042002                    # [Required] [Public]
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network  # [Required] [Public]
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app  # [Required] [Public]
NEXT_PUBLIC_ARC_WS_URL=wss://rpc.testnet.arc.network  # [Required] [Public]

# ─────────────────────────────────────────────────────────────────────────────
# WalletConnect (Required for wallet connection)
# ─────────────────────────────────────────────────────────────────────────────
# Get project ID: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id  # [Required] [Public]

# ─────────────────────────────────────────────────────────────────────────────
# Stripe Crypto Onramp (Required for card payments)
# ─────────────────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/crypto-onramp
# Test card: 4242 4242 4242 4242, OTP: 000000, SSN: 000000000
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key    # [Required] [Server]
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key  # [Required] [Public]
# Webhook secret: stripe listen --forward-to localhost:3000/api/crypto/onramp/webhook
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET     # [Required] [Server]

# ─────────────────────────────────────────────────────────────────────────────
# Backend API (Optional — enables FastAPI proxy)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000            # [Optional] [Public]

# ─────────────────────────────────────────────────────────────────────────────
# Analytics (Optional)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_token_here  # [Optional] [Public]
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com    # [Optional] [Public]
NEXT_PUBLIC_SIMPLE_ANALYTICS_HOSTNAME=rosetta-alpha.vercel.app  # [Optional] [Public]

# ─────────────────────────────────────────────────────────────────────────────
# x402 Micropayments (Optional — for demo, uses dev bypass)
# ─────────────────────────────────────────────────────────────────────────────
X402_DEV_BYPASS_TOKEN=                               # [Optional] [Server]
X402_SELLER_ADDRESS=                                  # [Optional] [Server]
X402_USDC_ADDRESS=                                    # [Optional] [Server]
ROSETTA_TREASURY_ADDRESS=                             # [Optional] [Server]
ARC_SETTLER_PRIVATE_KEY=                              # [Required for quiz/thesis] [Server]
