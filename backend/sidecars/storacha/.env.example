# Storacha Sidecar Environment Variables
# Copy to .env and fill in values from the provisioning step.

# Ed25519 private key for the Storacha agent (from `w3 key create`)
STORACHA_AGENT_KEY=

# Base64-encoded CAR file with space access delegation
# Generate: w3 delegation create <agent-did> --can 'space/blob/add' --can 'upload/add' --expiration $(($(date +%s) + 31536000)) --output delegation.car
# Encode:   base64 -i delegation.car (macOS) or base64 -w0 delegation.car (Linux)
STORACHA_DELEGATION=

# Port for the sidecar HTTP server (default: 3030)
STORACHA_PORT=3030
