# Circle Paymaster Demo — Environment Variables
# Copy this to .env and fill in your values

# Your deployer/agent wallet private key (0x-prefixed)
OWNER_PRIVATE_KEY=0x...

# Address to receive the 0.01 USDC test transfer
RECIPIENT_ADDRESS=0x...

# Circle Paymaster contract on Arbitrum Sepolia (ERC-4337 v0.7)
# No need to change — this is Circle's deployed address
PAYMASTER_V07_ADDRESS=0x31BE08D380A21fc740883c0BC434FcFc88740b58

# Testnet USDC on Arbitrum Sepolia
# Mint free testnet USDC at: https://faucet.circle.com
USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
